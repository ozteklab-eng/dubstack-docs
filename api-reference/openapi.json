{
  "openapi": "3.1.0",
  "info": {
    "title": "DubStack Docs Runtime API",
    "version": "2026-06-25",
    "description": "Public endpoints exposed by a published DubStack docs site for AI access, assistant chat, LLM-readable exports, and browser API playground execution. These endpoints run on each published docs domain and are scoped to that site."
  },
  "servers": [
    {
      "url": "https://dubstack-docs-test.dubstack.live",
      "description": "Published docs site"
    }
  ],
  "tags": [
    {
      "name": "AI Access",
      "description": "Endpoints agents and AI clients use to read published documentation."
    },
    {
      "name": "Assistant",
      "description": "Reader-facing assistant endpoints for published docs sites."
    },
    {
      "name": "API Playground",
      "description": "Endpoints used by the API playground to load specs and proxy safe test requests."
    }
  ],
  "paths": {
    "/mcp": {
      "get": {
        "operationId": "getMcpDiscovery",
        "summary": "Get MCP discovery",
        "description": "Returns the public Model Context Protocol discovery document for the current docs site. Use this endpoint to verify that the site exposes a read-only MCP surface for agents and MCP-capable clients.",
        "tags": [
          "AI Access"
        ],
        "responses": {
          "200": {
            "description": "Public MCP discovery metadata for the current docs site.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/McpDiscovery"
                },
                "examples": {
                  "discovery": {
                    "summary": "Discovery response",
                    "value": {
                      "name": "DubStack Docs MCP",
                      "description": "Read-only MCP server for the published docs site.",
                      "transport": "streamable-http",
                      "endpoint": "https://dubstack-docs-test.dubstack.live/mcp",
                      "capabilities": {
                        "tools": [
                          "search",
                          "query_docs_filesystem"
                        ],
                        "resources": [
                          "skill.md"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "callMcpServer",
        "summary": "Call MCP server",
        "description": "Handles Streamable HTTP JSON-RPC requests for the public docs MCP server. Public MCP tools are read-only and scoped to the published documentation for the current site.",
        "tags": [
          "AI Access"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JsonRpcRequest"
              },
              "examples": {
                "toolsList": {
                  "summary": "List available tools",
                  "value": {
                    "jsonrpc": "2.0",
                    "id": 1,
                    "method": "tools/list"
                  }
                },
                "searchDocs": {
                  "summary": "Search published docs",
                  "value": {
                    "jsonrpc": "2.0",
                    "id": 2,
                    "method": "tools/call",
                    "params": {
                      "name": "search",
                      "arguments": {
                        "query": "custom domain setup",
                        "limit": 5
                      }
                    }
                  }
                }
              }
            }
          },
          "description": "JSON-RPC request sent by an MCP client."
        },
        "responses": {
          "200": {
            "description": "JSON-RPC response from the public MCP server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JsonRpcResponse"
                },
                "examples": {
                  "tools": {
                    "summary": "Tool list response",
                    "value": {
                      "jsonrpc": "2.0",
                      "id": 1,
                      "result": {
                        "tools": [
                          {
                            "name": "search",
                            "description": "Search the published docs for relevant pages."
                          },
                          {
                            "name": "query_docs_filesystem",
                            "description": "Read published docs through a read-only virtual filesystem."
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "closeMcpSession",
        "summary": "Close MCP session",
        "description": "Closes a Streamable HTTP MCP session. Clients call this when they no longer need a session-bound MCP connection.",
        "tags": [
          "AI Access"
        ],
        "responses": {
          "200": {
            "description": "Session close acknowledgement.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "description": "Whether the session close request was accepted.",
                      "example": true
                    }
                  },
                  "required": [
                    "ok"
                  ]
                },
                "examples": {
                  "closed": {
                    "summary": "Session closed",
                    "value": {
                      "ok": true
                    }
                  }
                }
              }
            }
          },
          "204": {
            "description": "Session closed without a response body."
          }
        }
      }
    },
    "/.well-known/mcp/server-card.json": {
      "get": {
        "operationId": "getMcpServerCard",
        "summary": "Get MCP server card",
        "description": "Returns a single server-card document that MCP-capable clients can use to discover the docs site's public MCP endpoint.",
        "tags": [
          "AI Access"
        ],
        "responses": {
          "200": {
            "description": "Server card that describes the public MCP endpoint for this docs site.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/McpServerCard"
                },
                "examples": {
                  "serverCard": {
                    "summary": "Public docs MCP server card",
                    "value": {
                      "name": "DubStack Docs MCP",
                      "description": "Read-only MCP access to the published docs site.",
                      "url": "https://dubstack-docs-test.dubstack.live/mcp",
                      "transport": "streamable-http"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/.well-known/mcp/server-cards.json": {
      "get": {
        "operationId": "getMcpServerCards",
        "summary": "Get MCP server cards",
        "description": "Returns all server cards advertised by the docs site.",
        "tags": [
          "AI Access"
        ],
        "responses": {
          "200": {
            "description": "MCP server cards collection.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "servers": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/McpServerCard"
                      }
                    }
                  },
                  "required": [
                    "servers"
                  ]
                },
                "examples": {
                  "serverCards": {
                    "summary": "Server cards collection",
                    "value": {
                      "servers": [
                        {
                          "name": "DubStack Docs MCP",
                          "description": "Read-only MCP access to the published docs site.",
                          "url": "https://dubstack-docs-test.dubstack.live/mcp",
                          "transport": "streamable-http"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/llms.txt": {
      "get": {
        "operationId": "getLlmsIndex",
        "summary": "Get LLM index",
        "description": "Returns the compact LLM-readable index for the current docs site. This export gives agents a fast overview of published pages, canonical URLs, and the highest-value entry points without requiring a browser.",
        "tags": [
          "AI Access"
        ],
        "responses": {
          "200": {
            "description": "Compact plain-text index of the published docs site.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                },
                "examples": {
                  "index": {
                    "summary": "Compact LLM index",
                    "value": "# DubStack Docs\n\n> Product documentation for building, publishing, and operating DubStack docs sites.\n\n## Pages\n- [Quickstart](https://dubstack-docs-test.dubstack.live/quickstart)\n- [MCP](https://dubstack-docs-test.dubstack.live/ai/mcp)\n- [API reference](https://dubstack-docs-test.dubstack.live/api-reference/introduction)"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/llms-full.txt": {
      "get": {
        "operationId": "getFullLlmsIndex",
        "summary": "Get full LLM index",
        "description": "Returns the expanded LLM-readable export for the current docs site. Use this when an agent needs deeper page context and more body content than the compact index provides.",
        "tags": [
          "AI Access"
        ],
        "responses": {
          "200": {
            "description": "Expanded plain-text export with page summaries and selected body content.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                },
                "examples": {
                  "fullIndex": {
                    "summary": "Expanded LLM index",
                    "value": "# DubStack Docs\n\n## Quickstart\nLaunch a docs site, connect Git, customize content, and publish.\n\n## Public MCP\nDubStack exposes read-only MCP tools so agents can search and inspect published docs."
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/chat": {
      "post": {
        "operationId": "askAssistant",
        "summary": "Ask assistant",
        "description": "Sends a reader question to the public docs assistant for the current site. The assistant answers from the published documentation and returns source links when retrieval finds relevant pages.",
        "tags": [
          "Assistant"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssistantRequest"
              },
              "examples": {
                "question": {
                  "summary": "Ask a docs question",
                  "value": {
                    "message": "How do I connect a custom domain?",
                    "page": "/deployment/custom-domains"
                  }
                }
              }
            }
          },
          "description": "Reader question and optional page context for the public assistant."
        },
        "responses": {
          "200": {
            "description": "Assistant answer generated from the published docs, with optional source citations.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssistantResponse"
                },
                "examples": {
                  "answer": {
                    "summary": "Assistant answer",
                    "value": {
                      "answer": "Open Settings, choose Domain setup, enter your domain, then add the DNS records shown in the dashboard. Once DNS propagates, verify the domain and publish your site.",
                      "sources": [
                        {
                          "title": "Custom domains",
                          "url": "https://dubstack-docs-test.dubstack.live/deployment/custom-domains",
                          "path": "/deployment/custom-domains"
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Assistant backend is unavailable."
          }
        }
      }
    },
    "/api/playground/spec": {
      "get": {
        "operationId": "getPlaygroundSpec",
        "summary": "Get playground spec",
        "description": "Loads a published OpenAPI specification for the current docs site. The docs renderer uses this endpoint to build API reference pages and the browser playground from the same source document.",
        "tags": [
          "API Playground"
        ],
        "parameters": [
          {
            "name": "spec",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "api-reference"
            },
            "description": "Spec name from dubstack.json or the default api-reference spec."
          },
          {
            "name": "branch",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Optional preview branch to read from when rendering branch preview docs."
          }
        ],
        "responses": {
          "200": {
            "description": "Published OpenAPI spec metadata and the parsed OpenAPI document.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublishedSpec"
                },
                "examples": {
                  "spec": {
                    "summary": "Loaded API reference spec",
                    "value": {
                      "name": "api-reference",
                      "display_name": "DubStack Docs Runtime API",
                      "base_url": "https://dubstack-docs-test.dubstack.live",
                      "spec_content": {
                        "openapi": "3.1.0",
                        "info": {
                          "title": "DubStack Docs Runtime API",
                          "version": "2026-06-25"
                        },
                        "paths": {
                          "/mcp": {
                            "get": {
                              "summary": "Get MCP discovery"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Spec not found."
          }
        }
      }
    },
    "/api/playground/proxy": {
      "post": {
        "operationId": "proxyPlaygroundRequest",
        "summary": "Proxy playground request",
        "description": "Proxies a reader-triggered playground request to an origin allowed by the published OpenAPI spec. The proxy keeps browser playground calls scoped to documented operations and avoids exposing tenant secrets in the frontend.",
        "tags": [
          "API Playground"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaygroundProxyRequest"
              },
              "examples": {
                "call": {
                  "summary": "Proxy a documented endpoint request",
                  "value": {
                    "url": "https://dubstack-docs-test.dubstack.live/mcp",
                    "method": "GET",
                    "headers": {
                      "Accept": "application/json"
                    }
                  }
                }
              }
            }
          },
          "description": "Request generated by the browser playground for an allowed URL."
        },
        "responses": {
          "200": {
            "description": "Captured upstream response returned to the browser playground.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlaygroundProxyResponse"
                },
                "examples": {
                  "proxiedResponse": {
                    "summary": "Proxied response",
                    "value": {
                      "status": 200,
                      "headers": {
                        "content-type": "application/json"
                      },
                      "body": {
                        "name": "DubStack Docs MCP",
                        "transport": "streamable-http",
                        "endpoint": "https://dubstack-docs-test.dubstack.live/mcp"
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Target origin is not allowed by the published spec."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "McpDiscovery": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable name for the docs MCP server.",
            "example": "DubStack Docs MCP"
          },
          "description": {
            "type": "string",
            "description": "Short description of what the MCP server exposes.",
            "example": "Read-only MCP server for the published docs site."
          },
          "transport": {
            "type": "string",
            "description": "MCP transport supported by this endpoint.",
            "enum": [
              "streamable-http"
            ],
            "example": "streamable-http"
          },
          "endpoint": {
            "type": "string",
            "format": "uri",
            "description": "Absolute URL clients should use for MCP requests.",
            "example": "https://dubstack-docs-test.dubstack.live/mcp"
          },
          "capabilities": {
            "type": "object",
            "description": "High-level feature summary for discovery clients.",
            "additionalProperties": true,
            "properties": {
              "tools": {
                "type": "array",
                "description": "Read-only MCP tools available for the published docs site.",
                "items": {
                  "type": "string"
                },
                "example": [
                  "search",
                  "query_docs_filesystem"
                ]
              },
              "resources": {
                "type": "array",
                "description": "Static MCP resources exposed by the docs site.",
                "items": {
                  "type": "string"
                },
                "example": [
                  "skill.md"
                ]
              }
            }
          }
        },
        "required": [
          "name",
          "transport",
          "endpoint"
        ]
      },
      "McpServerCard": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name for the public docs MCP server.",
            "example": "DubStack Docs MCP"
          },
          "description": {
            "type": "string",
            "description": "Short explanation of the server purpose.",
            "example": "Read-only MCP access to the published docs site."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Absolute MCP endpoint URL.",
            "example": "https://dubstack-docs-test.dubstack.live/mcp"
          },
          "transport": {
            "type": "string",
            "description": "Transport protocol used by the MCP endpoint.",
            "enum": [
              "streamable-http"
            ],
            "example": "streamable-http"
          }
        },
        "required": [
          "name",
          "description",
          "url"
        ]
      },
      "JsonRpcRequest": {
        "type": "object",
        "properties": {
          "jsonrpc": {
            "type": "string",
            "description": "JSON-RPC protocol version. MCP uses 2.0.",
            "example": "2.0"
          },
          "id": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ],
            "description": "Client-generated request identifier returned in the matching response.",
            "example": 1
          },
          "method": {
            "type": "string",
            "description": "MCP JSON-RPC method to invoke, such as tools/list or tools/call.",
            "example": "tools/list"
          },
          "params": {
            "type": "object",
            "description": "Method-specific parameters. Tool calls include a tool name and arguments object.",
            "additionalProperties": true,
            "example": {
              "name": "search",
              "arguments": {
                "query": "custom domain setup",
                "limit": 5
              }
            }
          }
        },
        "required": [
          "jsonrpc",
          "method"
        ]
      },
      "JsonRpcResponse": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "jsonrpc": {
            "type": "string",
            "description": "JSON-RPC protocol version.",
            "example": "2.0"
          },
          "id": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Identifier from the request, or null for responses that cannot be matched to a request.",
            "example": 1
          },
          "result": {
            "type": "object",
            "description": "Successful method result. Shape depends on the MCP method.",
            "additionalProperties": true
          },
          "error": {
            "type": "object",
            "description": "JSON-RPC error object when the request fails.",
            "additionalProperties": true,
            "properties": {
              "code": {
                "type": "number",
                "description": "JSON-RPC error code.",
                "example": -32601
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message.",
                "example": "Method not found"
              }
            }
          }
        },
        "required": [
          "jsonrpc"
        ]
      },
      "AssistantRequest": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "message": {
            "type": "string",
            "description": "Reader question to answer from the published docs."
          },
          "question": {
            "type": "string",
            "description": "Alternate question field accepted by clients that send question instead of message."
          },
          "page": {
            "type": "string",
            "description": "Optional current docs page path used as local context for the answer."
          }
        },
        "description": "Question payload sent by the public assistant widget.",
        "example": {
          "message": "How do I publish a preview deployment?",
          "page": "/deployment/preview-deployments"
        }
      },
      "AssistantResponse": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "answer": {
            "type": "string",
            "description": "Assistant response text generated from published documentation."
          },
          "message": {
            "type": "string",
            "description": "Alternate answer field returned by compatibility paths."
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "description": "Published docs pages used as supporting context for the answer."
          }
        },
        "description": "Answer returned by the public assistant widget.",
        "example": {
          "answer": "Create a branch preview from the dashboard, review the generated URL, then merge or publish when ready.",
          "sources": [
            {
              "title": "Preview deployments",
              "url": "https://dubstack-docs-test.dubstack.live/deployment/preview-deployments",
              "path": "/deployment/preview-deployments"
            }
          ]
        }
      },
      "PublishedSpec": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Stable spec identifier configured for the docs site."
          },
          "display_name": {
            "type": "string",
            "description": "Human-friendly spec title shown in the dashboard and public docs."
          },
          "base_url": {
            "type": [
              "string",
              "null"
            ],
            "description": "Preferred base URL used by the playground when the spec does not define a server URL."
          },
          "spec_content": {
            "type": "object",
            "additionalProperties": true,
            "description": "Parsed OpenAPI document used to render endpoint docs and playground controls."
          }
        },
        "required": [
          "name",
          "display_name",
          "spec_content"
        ],
        "description": "Wrapper returned by the spec loader, including display metadata and the parsed OpenAPI document.",
        "example": {
          "name": "api-reference",
          "display_name": "DubStack Docs Runtime API",
          "base_url": "https://dubstack-docs-test.dubstack.live",
          "spec_content": {
            "openapi": "3.1.0",
            "info": {
              "title": "DubStack Docs Runtime API",
              "version": "2026-06-25"
            },
            "paths": {}
          }
        }
      },
      "PlaygroundProxyRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Fully resolved URL for the documented operation selected in the playground."
          },
          "method": {
            "type": "string",
            "enum": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE",
              "OPTIONS",
              "HEAD"
            ],
            "description": "HTTP method for the documented operation."
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Headers supplied by the playground. Sensitive credentials should come from user input, not tenant defaults."
          },
          "body": {
            "description": "Request body supplied by the playground."
          }
        },
        "required": [
          "url"
        ],
        "description": "Browser playground request scoped to a URL allowed by the published OpenAPI spec.",
        "example": {
          "url": "https://dubstack-docs-test.dubstack.live/mcp",
          "method": "GET",
          "headers": {
            "Accept": "application/json"
          }
        }
      },
      "PlaygroundProxyResponse": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "status": {
            "type": "number",
            "description": "HTTP status returned by the upstream operation."
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Response headers returned by the upstream operation."
          },
          "body": {
            "description": "Parsed response body when JSON, otherwise the raw response text."
          }
        },
        "description": "Upstream response captured by the playground proxy.",
        "example": {
          "status": 200,
          "headers": {
            "content-type": "application/json"
          },
          "body": {
            "name": "DubStack Docs MCP",
            "transport": "streamable-http"
          }
        }
      }
    }
  }
}
